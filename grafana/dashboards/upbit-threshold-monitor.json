          "editorMode": "code",
          "format": "time_series",
          "metricColumn": "metric",
          "rawQuery": true,
          "rawSql": "WITH per_second AS (\n  SELECT\n    time_bucket('1 second', time) AS bucket,\n    market,\n    side,\n    SUM(trade_value) AS value_krw\n  FROM trades\n  WHERE $__timeFilter(time)\n  GROUP BY 1, 2, 3\n), active_markets AS (\n  SELECT market\n  FROM per_second\n  WHERE side = 'BID'\n  GROUP BY market\n  HAVING MAX(value_krw) >= ${threshold_krw:raw}\n)\nSELECT\n  bucket AS \"time\",\n  market AS metric,\n  value_krw AS value\nFROM per_second\nWHERE side = 'BID'\n  AND market IN (SELECT market FROM active_markets)\nORDER BY 1, 2;",
          "refId": "A",
